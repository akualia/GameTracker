<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameTracker.Views.GameDetailView"
             Shell.NavBarIsVisible="False" BackgroundColor="#FFFFFF">

    <!-- Main scrollable container -->
    <ScrollView>
        <Grid>
            <!-- Game background image -->
            <Image Source="{Binding SelectedGame.BackgroundImage}" 
                   HeightRequest="300" 
                   Aspect="AspectFill" 
                   VerticalOptions="Start"/>

            <!-- Top overlay (Back button + Favorite button) -->
            <Grid Padding="20,40,20,0" VerticalOptions="Start">
                
                <!-- Back button -->
                <Border HorizontalOptions="Start" StrokeShape="RoundRectangle 25" WidthRequest="45" HeightRequest="45" BackgroundColor="White" Stroke="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="←" FontSize="24" TextColor="Black" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- Favorite button (currently UI only) -->
                <Border HorizontalOptions="End" StrokeShape="RoundRectangle 25" WidthRequest="45" HeightRequest="45" BackgroundColor="#E63946" Stroke="Transparent">
                    <Label Text="🤍" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- Main content section -->
            <VerticalStackLayout Margin="0,270,0,0" Spacing="0">

                <!-- Rounded top container -->
                <Border BackgroundColor="#FFFFFF" Stroke="Transparent" StrokeShape="RoundRectangle 25,25,0,0" Padding="25">
                    <VerticalStackLayout Spacing="15">

                        <!-- Game title and rating -->
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">

                            <!-- Game name -->
                            <Label Grid.Column="0" Text="{Binding SelectedGame.Name}" FontSize="26" FontAttributes="Bold" TextColor="#3A3A4D" LineBreakMode="TailTruncation" MaxLines="2"/>

                            <!-- Game rating -->
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding SelectedGame.Rating}" FontSize="14" TextColor="#777" VerticalOptions="Center"/>
                                <Label Text="⭐" FontSize="18" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Placeholder metadata (static for now) -->
                        <Label Text="45 MIN • RECENTLY PLAYED       GENRE: ACTION" FontSize="11" TextColor="#888" FontAttributes="Bold" />

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10" />

                        <!-- User input section (status + progress) -->
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="20" Margin="0,10,0,20">
                            <VerticalStackLayout Spacing="15">

                                <!-- Play status -->
                                <Label Text="สถานะการเล่น" TextColor="Black" FontAttributes="Bold" FontSize="14"/>
                                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9">
                                    <Picker Title="-- เลือกสถานะ --" 
                                            SelectedItem="{Binding SelectedGame.PlayStatus}"
                                            TextColor="Black" TitleColor="Gray" Margin="10,0">
                                        <Picker.Items>
                                            <x:String>Plan to Play</x:String>
                                            <x:String>Playing</x:String>
                                            <x:String>Completed</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>

                                <!-- Progress input -->
                                <Label Text="ความคืบหน้า (%)" TextColor="Black" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0"/>
                                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9">
                                    <Entry Placeholder="เช่น 50" 
                                           Text="{Binding SelectedGame.Progress}"
                                           Keyboard="Numeric" 
                                           TextColor="Black" 
                                           Margin="10,0"/>
                                </Border>

                            </VerticalStackLayout>
                        </Border>

                        <!-- Save button -->
                        <Button  Text="Add to library" 
                                Command="{Binding AddToLibraryCommand}" 
                                BackgroundColor="#7A75FF" 
                                TextColor="White" 
                                FontSize="16"
                                FontAttributes="Bold"
                                CornerRadius="25"
                                HeightRequest="55"
                                Margin="0,10,0,30"
                                Shadow="{Shadow Brush=#7A75FF, Offset='0,5', Opacity=0.3, Radius=10}"/>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>